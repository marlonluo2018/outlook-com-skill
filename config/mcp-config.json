{
  "mcpServers": {
    "outlook": {
      "description": "Microsoft Outlook email management MCP server",
      "command": "python",
      "args": ["-m", "outlook_mcp_server"],
      "cwd": "C:\\project\\outlook-mcp-server",
      "env": {},
      "settings": {
        "max_email_cache": 500,
        "emails_per_page": 5,
        "max_batch_size": 500,
        "default_days_back": 7
      }
    }
  },
  "installation": {
    "server_path": "C:\\project\\outlook-mcp-server",
    "repository": "https://github.com/marlonluo2018/outlook-mcp-server.git",
    "required_python": ">=3.8",
    "dependencies": [
      "fastmcp==2.13.1",
      "pywin32==311"
    ]
  },
  "requirements": {
    "outlook_version": "Microsoft Outlook 2016+",
    "os": "Windows 10+",
    "outlook_must_be_running": true
  },
  "operations": {
    "search": {
      "types": ["recent", "subject", "sender", "recipient", "body"],
      "max_days_back": 30,
      "default_days": 7
    },
    "compose": {
      "requires_confirmation": true,
      "max_recipients": 500
    },
    "batch_forward": {
      "max_batch_size": 500,
      "csv_format": "email column required",
      "uses_bcc": true
    },
    "folder": {
      "operations": ["list", "create", "move", "delete"],
      "requires_confirmation": ["delete"]
    }
  },
  "security": {
    "local_processing": true,
    "no_cloud_services": true,
    "data_stays_local": true,
    "uses_existing_outlook": true
  }
}